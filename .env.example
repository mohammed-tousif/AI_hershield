PORT=3000
# If PORT is busy, the server tries PORT+1 … up to PORT+PORT_RANGE (default 25).
# PORT_RANGE=25
NODE_ENV=development

# Behind nginx/Render/etc. set to 1 so rate limits and IPs are correct
# TRUST_PROXY=1

# Public URL of your backend (Render URL or local). Used for API callbacks.
APP_URL=http://localhost:3000

# Public URL of your frontend (Firebase Hosting). Used for share/tracking links in emails.
FRONTEND_URL=http://localhost:3000

# MongoDB — not used by Her Shield API data (Firestore is the source of truth).
# MONGODB_URI=

# Firebase Web SDK (reference — client uses firebase-config.js; keep values in sync)
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Firebase Admin — REQUIRED for posts, incidents, users, tracking, etc.
# Firebase Console → Project settings → Service accounts → Generate new private key → save as a .json file.
#
# Recommended on Windows (avoid broken JSON in .env):
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-adminsdk-xxxxx.json
#
# Or use Google’s standard variable (same value: path to that file):
# GOOGLE_APPLICATION_CREDENTIALS=C:\full\path\to\serviceAccountKey.json
#
# On Render / CI, paste one line (escape inner quotes carefully):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-id",...}

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Business API (optional)
WHATSAPP_API_KEY=your_whatsapp_api_key_here
WHATSAPP_PHONE_NUMBER=+1234567890

# Google Maps (restrict key by HTTP referrer in Google Cloud Console)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Email — sent via the Gmail REST API over HTTPS, NOT SMTP.
# (Render blocks outbound SMTP entirely on every port; confirmed by direct
# testing. The Gmail API is a plain HTTPS JSON API, so it isn't affected.)
#
# EMAIL_USER = the Gmail address you're sending FROM (e.g. developerclub63@gmail.com)
# The three GMAIL_OAUTH_* values come from a one-time setup in Google Cloud Console:
#   1. console.cloud.google.com → select/create a project (your Firebase project
#      works fine, since Firebase projects ARE Google Cloud projects)
#   2. APIs & Services → Library → enable "Gmail API"
#   3. APIs & Services → OAuth consent screen → External → add EMAIL_USER as a test user
#      → add scope https://www.googleapis.com/auth/gmail.send
#   4. APIs & Services → Credentials → Create Credentials → OAuth client ID →
#      Application type "Desktop app" → gives you Client ID + Client Secret
#   5. Use https://developers.google.com/oauthplayground (gear icon → "Use your
#      own OAuth credentials" → paste Client ID/Secret) → authorize the
#      gmail.send scope signed in as EMAIL_USER → exchange for a refresh token
EMAIL_USER=your_gmail_address
GMAIL_OAUTH_CLIENT_ID=your_oauth_client_id
GMAIL_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GMAIL_OAUTH_REFRESH_TOKEN=your_oauth_refresh_token

# Session / JWT — use long random strings in production
SESSION_SECRET=change_me_session_secret
JWT_SECRET=change_me_jwt_secret

# Live tracker tuning (optional)
VERIFY_INTERVAL=120000
PIN_TIMEOUT=20000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
